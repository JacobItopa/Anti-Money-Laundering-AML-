# =============================================================
#  AML Fraud Detection — .gitignore
# =============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual Environments ──────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Jupyter Notebooks ─────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data — Raw (large CSVs, never commit raw data) ───────────
data/raw/
data/external/

# ── Data — Processed & Interim (regenerated by pipeline) ─────
data/processed/
data/interim/

# ── Serialised Models (too large / regenerated by pipeline) ──
# Uncomment the line below if you want to also exclude models:
# models/

# ── Reports / Figures (auto-generated) ───────────────────────
reports/figures/

# ── OS & Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Pytest & Coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Misc ──────────────────────────────────────────────────────
*.log
*.tmp
